<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base theme; Compose drives the real colors. We keep the system bars dark
         so the app feels like a full-bleed editor from the first frame. -->
    <style name="Theme.NeverSoftEditor" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/ns_bg</item>
        <item name="android:statusBarColor">@color/ns_bg</item>
        <item name="android:navigationBarColor">@color/ns_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
