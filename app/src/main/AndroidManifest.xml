<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Reading media is done through the Android Photo Picker, which grants
         scoped, per-item access without any storage permission. We ask for
         nothing up front, so the app opens instantly with zero permission
         dialogs. Saved exports are written via MediaStore (no permission on
         API 29+; minSdk is 26 so we add the legacy WRITE for 26–28). -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- One-time download of the on-device stem-separation model. All audio
         processing runs locally; only the model file is fetched over the network. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".NeverSoftApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.NeverSoftEditor">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:theme="@style/Theme.NeverSoftEditor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
